// Student menu
void student_menu() {
    int choice;

    do {
        clear_screen();
        print_header("STUDENT MENU");
        printf("1. View My Result\n");
        printf("2. View Class Ranking\n");
        printf("3. Logout\n");
        printf("\nChoice: ");

        choice = read_int();

        if (choice == 1) {
            printf("\n");
            display_result();
            pause_screen();
        } else if (choice == 2) {
            show_ranking();
            pause_screen();
