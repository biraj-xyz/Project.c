            logged_in = 0;
        } else {
            printf("Invalid choice!\n");
            pause_screen();
        }

    } while (choice != 3);
}

// Main function
int main() {
    // Load existing data
    load_students();
    load_users();

    // Initialize default data if needed
    init_data();

    int choice;

    do {
        clear_screen();
        print_header("STUDENT RESULT MANAGEMENT SYSTEM");

        if (!logged_in) {
            printf("1. Login\n");
            printf("2. Exit\n");
            printf("\nChoice: ");

            choice = read_int();

            if (choice == 1) {
                login();
            } else if (choice == 2) {
                break;
            } else {
                printf("Invalid choice!\n");
                pause_screen();
            }
        } else {
            // Show appropriate menu based on role
            if (strcmp(current_user.role, "admin") == 0) {
                admin_menu();
            } else if (strcmp(current_user.role, "teacher") == 0) {
                teacher_menu();
            } else if (strcmp(current_user.role, "student") == 0) {
                student_menu();
            }
        }

    } while (1);

    // Save data before exit
    save_students();
    save_users();

    printf("\nThank you for using the system!\n");
    return 0;
}

